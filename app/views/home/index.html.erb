<% content_for :head do %>
  <%= vite_typescript_tag 'home.tsx' %>
<% end %>

<div id="root"
     data-dri="<%= @dri %>"
     data-api-key="<%= @integration_settings&.settings&.dig('api_key') %>"
     data-api-secret="<%= @integration_settings&.settings&.dig('api_secret') %>"
     data-hold-for-batch="<%= @integration_settings&.hold_for_batch ? 'true' : 'false' %>"
     data-batch-window-minutes="<%= @integration_settings&.batch_window_minutes %>"
     data-api-version="<%= @integration_settings&.api_version || 'v1' %>"
     data-v2-api-key="<%= @integration_settings&.settings&.dig('v2_api_key') %>">
</div>
